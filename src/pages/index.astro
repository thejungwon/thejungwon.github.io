---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

import { profile } from '@/settings'
import ProfilePictures from '@/assets/profile.png'
import Hero from '@/components/ui/Hero.astro'

const { fullName, title, institute } = profile
const blogEntries = await getCollection('blog')
const orderedNews = [...blogEntries]
	.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
	.slice(0, 8)

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<!-- Hero Section -->
	<section class='flex items-center gap-12 border-b pb-12'>
		<Hero
			fullName={fullName}
			title={title}
			institute={institute}
			profilePicture={ProfilePictures}
		/>
	</section>

	<!-- What I Do -->
	<section class='py-12 border-b'>
		<h2 class='text-3xl font-bold mb-8'>What I Do</h2>
		<div class='grid gap-6 md:grid-cols-3'>
			<div class='p-6 bg-base-200 rounded-xl'>
				<h3 class='text-xl font-semibold mb-2'>Research</h3>
				<p class='text-sm opacity-90'>
					Practical research centered on Federated Learning, expanded through a privacy-preserving lens. Current focus: sensitive information leakage risks in AI agents.
				</p>
			</div>
			<div class='p-6 bg-base-200 rounded-xl'>
				<h3 class='text-xl font-semibold mb-2'>Software Engineering</h3>
				<p class='text-sm opacity-90'>
					Full-stack engineering from CSS to DevOps, with hands-on startup experience building systems from scratch and running deployment/operations in production.
				</p>
			</div>
			<div class='p-6 bg-base-200 rounded-xl'>
				<h3 class='text-xl font-semibold mb-2'>Teaching</h3>
				<p class='text-sm opacity-90'>
					Hands-on teaching in SWE, AI, and ML, with content flexibly tailored for both academic and industry audiences.
				</p>
			</div>
		</div>
	</section>

	<!-- News -->
	<section class='py-12 border-t'>
		<h2 class='text-3xl font-bold mb-8'>News</h2>
		<div class='space-y-4'>
			{
				orderedNews.map((item) => (
					<article class='p-5 rounded-lg bg-base-200'>
						<div class='flex flex-wrap items-center gap-2 mb-2 text-sm opacity-80'>
							<span class='badge badge-outline'>{item.data.tags?.[0] ?? 'Update'}</span>
							<span>{new Date(item.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
						</div>
						<h3 class='text-lg font-semibold'>
							<a href={`/news/${item.id}`} class='hover:text-accent'>{item.data.title}</a>
						</h3>
						<p class='mt-1 text-sm opacity-90'>{item.data.excerpt}</p>
					</article>
				))
			}
		</div>
		<div class='mt-8 text-center'>
			<a
				href='/news/1'
				class='btn btn-secondary text-secondary-content'
			>
				See More
			</a>
		</div>
	</section>
</Layout>
