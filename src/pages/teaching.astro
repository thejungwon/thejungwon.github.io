---
import Layout from '@/layouts/Layout.astro';
import { teachingItems, supervisionItems } from '@/data/teaching';
---

<Layout>
  <section class='mb-12'>
    <h2 class='text-2xl font-bold mb-6 border-b pb-2'>Teaching</h2>
    <div class='grid gap-4'>
      {teachingItems.map((item) => (
        <article class='p-5 bg-base-200 rounded-xl text-base-content'>
          <h3 class='text-lg font-bold'>{item.course}</h3>
          <p class='font-semibold mt-1'>{item.role} · {item.institution}</p>
          <p class='opacity-80'>{item.time}</p>
          {item.notes && <p class='mt-2'>{item.notes}</p>}
        </article>
      ))}
    </div>
  </section>

  <section class='mb-12'>
    <h2 class='text-2xl font-bold mb-6 border-b pb-2'>Supervision</h2>
    <div class='grid gap-4'>
      {supervisionItems.map((item) => (
        <article class='p-5 bg-base-200 rounded-xl text-base-content'>
          <h3 class='text-lg font-bold'>{item.student}</h3>
          <p class='font-semibold mt-1'>{item.degree} · {item.institution}</p>
          <p class='opacity-80'>{item.time}</p>
          {item.thesisTitle && <p class='mt-2'>- Title: {item.thesisTitle}</p>}
          {item.coSupervision && <p>- {item.coSupervision}</p>}
        </article>
      ))}
    </div>
  </section>
</Layout>
